# ──────────────────────────────────────────
# Zomato Clone - Environment Configuration
# ──────────────────────────────────────────
# Copy this file to .env and fill in values
# NEVER commit your actual .env to GitHub!
# cp .env.example .env

# App
NODE_ENV=development
REACT_APP_NAME=ZomatoClone
REACT_APP_VERSION=1.0.0

# API (for future backend integration)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=5000

# Docker
DOCKER_IMAGE_NAME=zomato-clone
DOCKER_IMAGE_TAG=latest
CONTAINER_PORT=3000

# DockerHub (CI/CD - set these as GitHub Secrets)
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_TOKEN=your_dockerhub_access_token

# AWS EC2 (CI/CD - set these as GitHub Secrets)
# EC2_HOST=your_ec2_public_ip
# EC2_USER=ubuntu
# EC2_SSH_KEY=your_private_key_content

# SonarQube (optional - for local analysis)
# SONAR_HOST_URL=http://localhost:9000
# SONAR_TOKEN=your_sonar_token
